# Supabase project URL and publishable (anon) key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# PowerSync service URL.
VITE_POWERSYNC_URL=

# Google OAuth client (Google Cloud Console). Consumed by the local Supabase Auth server via
# env() substitution in supabase/config.toml - NOT shipped to the client. Leave empty to keep
# the Google button disabled locally (email/password still works). For prod, set the provider in
# the Supabase dashboard instead.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
