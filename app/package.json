{
  "name": "@finapp/app",
  "type": "module",
  "version": "8.2.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "description": "Finapp helps you easily track and manage personal finances.",
  "author": "Ilya Komichev @ilkome",
  "license": "MIT",
  "homepage": "https://ilko.me",
  "repository": "ilkome/finapp",
  "keywords": [
    "vue, nuxt, supabase, powersync, tailwind, pwa, echarts, swiper"
  ],
  "engines": {
    "node": ">=v24.12.0"
  },
  "scripts": {
    "build": "nuxt generate",
    "dev": "nuxt dev -p 3050 --public",
    "dev:prod": "nuxt dev -p 3050 --public --dotenv .env.prod",
    "generate": "nuxt generate",
    "preview": "nuxt generate && nuxt preview",
    "typecheck": "nuxi typecheck",
    "check:deps": "node scripts/check-single-reka-ui.mjs",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --project=demo",
    "test:e2e:prod": "playwright test --config=playwright.prod.config.ts",
    "test:e2e:headed": "playwright test --project=demo --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@date-fns/utc": "^2.1.1",
    "@formkit/drag-and-drop": "^0.6.1",
    "@iconify-json/mdi": "^1.2.3",
    "@internationalized/date": "^3.12.2",
    "@journeyapps/wa-sqlite": "^1.7.0",
    "@pinia/nuxt": "^0.11.3",
    "@powersync/web": "^1.38.4",
    "@supabase/supabase-js": "^2.108.2",
    "echarts": "^6.1.0",
    "fuse.js": "^7.4.2",
    "localforage": "^1.10.0",
    "motion-v": "^2.3.0",
    "pinia": "^3.0.4",
    "reka-ui": "2.9.10",
    "swiper": "^12.2.0",
    "vaul-vue": "^0.4.1",
    "vite": "^8.0.16",
    "vue": "^3.5.38",
    "vue-echarts": "^8.0.1"
  },
  "devDependencies": {
    "@iconify-json/hugeicons": "^1.2.29",
    "@iconify-json/lucide": "^1.2.114",
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/ui": "^4.9.0",
    "@nuxtjs/i18n": "^10.4.0",
    "@playwright/mcp": "^0.0.76",
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.0.0",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "defu": "^6.1.7",
    "dotenv": "^17.4.2",
    "es-toolkit": "^1.48.1",
    "happy-dom": "^20.10.6",
    "nuxt": "^4.4.8",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5",
    "workbox-core": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1",
    "zod": "^4.4.3"
  }
}
