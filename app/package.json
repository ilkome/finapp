{
  "name": "@finapp/app",
  "type": "module",
  "version": "7.10.0",
  "private": true,
  "description": "Finapp helps you easily track and manage personal finances.",
  "author": "Ilya Komichev @ilkome",
  "license": "MIT",
  "homepage": "https://ilko.me",
  "repository": "ilkome/finapp",
  "keywords": [
    "vue, nuxt, convex, tailwind, pwa, echarts, swiper"
  ],
  "engines": {
    "node": ">=v24.12.0"
  },
  "scripts": {
    "build": "nuxt build",
    "dev:convex": "npx convex dev",
    "dev": "nuxt dev -p 3050 --public",
    "dev:prod": "nuxt dev -p 3050 --public --dotenv .env.prod",
    "generate": "nuxt generate",
    "preview": "nuxt generate && nuxt preview",
    "typecheck": "nuxi typecheck",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --project=demo",
    "test:e2e:headed": "playwright test --project=demo --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:auth": "playwright test --project=auth-setup --headed",
    "test:e2e:real": "playwright test --project=real"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.11.3",
    "@formkit/drag-and-drop": "^0.5.3",
    "@iconify-json/mdi": "^1.2.3",
    "@internationalized/date": "^3.12.0",
    "@pinia/nuxt": "^0.11.3",
    "better-auth": "^1.5.6",
    "convex": "^1.34.0",
    "convex-helpers": "^0.1.114",
    "echarts": "^6.0.0",
    "fuse.js": "^7.1.0",
    "localforage": "^1.10.0",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.6",
    "swiper": "^12.1.3",
    "vaul-vue": "^0.4.1",
    "vite": "^8.0.2",
    "vue": "^3.5.30",
    "vue-echarts": "^8.0.1"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@iconify-json/lucide": "^1.2.98",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/ui": "^4.6.0",
    "@nuxtjs/i18n": "^10.2.4",
    "@playwright/mcp": "^0.0.70",
    "@playwright/test": "^1.55.0",
    "@types/node": "^25.5.0",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vitest/coverage-v8": "^4.1.1",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "clsx": "^2.1.1",
    "convex-test": "^0.0.44",
    "date-fns": "^4.1.0",
    "defu": "^6.1.4",
    "dotenv": "^17.3.1",
    "es-toolkit": "^1.45.1",
    "happy-dom": "^20.8.8",
    "nuxt": "^4.4.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1",
    "vue-tsc": "^3.2.8",
    "workbox-core": "^7.4.0",
    "workbox-precaching": "^7.4.0",
