{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter app generate",
  "outputDirectory": ".output/public",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- . ../package.json ../pnpm-lock.yaml ../pnpm-workspace.yaml",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
