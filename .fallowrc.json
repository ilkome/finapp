{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "autoImports": true,
  "ignoreExportsUsedInFile": true,
  "entry": [
    "app/app/app.vue",
    "app/app/app.config.ts",
    "app/app/error.vue",
    "app/app/pages/**/*.vue",
    "app/app/layouts/**/*.vue",
    "app/app/components/**/*.vue",
    "app/app/middleware/**/*.ts",
    "app/app/plugins/**/*.ts",
    "app/app/composables/**/*.ts",
    "app/app/utils/**/*.ts",
    "app/i18n/**/*.{ts,js}",
    "app/nuxt.config.ts",
    "app/scripts/**/*.mjs",
    "app/services/**/*.ts",
    "app/tests/**/*.ts",
    "**/*.test.ts"
  ],
  "ignorePatterns": [
    "**/.nuxt/**",
    "**/.output/**",
    "**/dist/**",
    "docs/**"
  ],
  "workspaces": {
    "packages": [
      "app",
      "docs"
    ]
  },
  "duplicates": {
    "minOccurrences": 3
  },
  "rules": {}
}
